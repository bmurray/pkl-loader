amends "@schema/Config.pkl"

appName = "import-app"

database {
  host = "localhost"
  port = 5432
  name = "testdb"
}

features {
  enableCache = true
  maxRetries = 3
}

sub {
  region = "us-east-1"
  enabled = true
}

nested {
  label = "primary"
  priority = 1
}

direct = import("overrides/direct_override.pkl")
